{
  "spark_version": {
    "type": "fixed",
    "value": "13.3.x-scala2.12",
    "hidden": false
  },
  "autotermination_minutes": {
    "type": "fixed",
    "value": 120,
    "hidden": false
  },
  "node_type_id": {
    "type": "allowlist",
    "values": [
      "Standard_DS3_v2",
      "Standard_DS4_v2"
    ],
    "defaultValue": "Standard_DS3_v2"
  },
  "num_workers": {
    "type": "range",
    "minValue": 1,
    "maxValue": 20,
    "defaultValue": 4
  }
}
